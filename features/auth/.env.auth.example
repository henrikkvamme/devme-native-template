# Copy to .env.auth.local and replace only the providers you want to configure.
AUTH_APP_NAME=Starter

# Google native sign-in
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign in with Apple. Keep the downloaded .p8 key outside this repository.
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_FILE=/absolute/path/to/AuthKey_KEYID.p8
APPLE_APP_BUNDLE_IDENTIFIER=
